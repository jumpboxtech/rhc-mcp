# Robinhood Chain RPC (defaults to the public mainnet RPC if unset)
RHC_RPC_URL=https://rpc.mainnet.chain.robinhood.com

# ---- Swapping (OPTIONAL) ----
# Only needed for the execute_swap tool. Read tools work without any key.
# The private key of the wallet that will send swaps. Keep it in a real secret
# store; never commit it. If unset, the server runs READ-ONLY and refuses swaps.
# Swaps route through Robinhood Chain's Uniswap v4 UniversalRouter — no contract
# to deploy. ERC-20 input flows through Permit2 (approvals handled automatically,
# and surfaced in the dry-run plan before anything is sent).
RHC_PRIVATE_KEY=

# Safety cap: execute_swap refuses any swap whose input value exceeds this many
# whole tokens of the input token. Defaults to 1 if unset. Set deliberately.
RHC_MAX_SWAP_AMOUNT=1
